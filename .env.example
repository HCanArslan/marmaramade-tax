# Obtain these from a Vercel Marketplace PostgreSQL provider.
# Use a pooled runtime URL for DATABASE_URL. Prisma automatically prefers
# DATABASE_URL_UNPOOLED/POSTGRES_URL_NON_POOLING from the Neon integration for
# migrations; DIRECT_URL is an optional explicit override for other providers.
DATABASE_URL="postgresql://USER:PASSWORD@POOL_HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/DATABASE?sslmode=require"

AUTH_SECRET=""
# Optional on Vercel when system environment variables are exposed.
NEXTAUTH_URL="https://your-production-domain.example"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""
AUTH_MAX_FAILED_ATTEMPTS="5"
AUTH_LOCKOUT_MINUTES="15"
AUTH_SESSION_MAX_AGE_HOURS="8"

TOKEN_ENCRYPTION_KEY=""

ETSY_API_KEYSTRING=""
ETSY_SHARED_SECRET=""
ETSY_REDIRECT_URI="http://localhost:3000/api/etsy/oauth/callback"
ETSY_SCOPES="shops_r listings_r transactions_r"
ETSY_WEBHOOK_SIGNING_SECRET=""
ETSY_RAW_PAYLOAD_RETENTION_DAYS="0"
