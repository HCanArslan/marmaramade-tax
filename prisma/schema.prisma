  amountTry  Decimal
  createdAt  DateTime @default(now())
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([expenseId, targetType, targetId])
}

model FixedAsset {
  id                          String             @id @default(cuid())
  businessProfileId           String
  name                        String
  category                    String
  acquisitionDate             DateTime
  acquisitionCost             Decimal
  currency                    String
  acquisitionCostTry          Decimal
  usefulLifeMonths            Int?
  depreciationMethod          String?
  depreciationStartDate       DateTime?
  accumulatedDepreciation     Decimal            @default(0)
  carryingValue               Decimal
  disposalDate                DateTime?
  documentId                  String?
  accountantReviewStatus      ConfirmationStatus @default(PENDING_ACCOUNTANT_CONFIRMATION)
  planningDepreciationEnabled Boolean            @default(false)
  notes                       String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  @@index([businessProfileId, acquisitionDate])
}

model Material {
  id                    String                         @id @default(cuid())
  sku                   String                         @unique
  name                  String
  unit                  String
  active                Boolean                        @default(true)
  reorderPoint          Decimal?
  notes                 String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  lots                  MaterialPurchaseLot[]
  inventoryTransactions MaterialInventoryTransaction[]
}

model MaterialPurchaseLot {
  id           String   @id @default(cuid())
  materialId   String
  purchasedAt  DateTime
  quantity     Decimal
  remaining    Decimal
  unitCostTry  Decimal
  documentId   String?
  supplierName String?
  createdAt    DateTime @default(now())
  material     Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([materialId, purchasedAt])
}

model MaterialInventoryTransaction {
  id            String   @id @default(cuid())
  materialId    String
  transactionAt DateTime
  type          String
  quantity      Decimal
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime @default(now())
  material      Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([materialId, transactionAt])
}

model ProductionBatch {
  id                    String           @id @default(cuid())
  batchCode             String           @unique
  productTemplateId     String
  makerPersonId         String
  startDate             DateTime
  completionDate        DateTime?
  status                String
  plannedQuantity       Int
  completedQuantity     Int              @default(0)
  rejectedQuantity      Int              @default(0)
  totalLaborHours       Decimal          @default(0)
  materialCostVersionId String?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  units                 ProductionUnit[]

  @@index([status, startDate])
}

model ProductionUnit {
  id                    String                         @id @default(cuid())
  batchId               String
  localSku              String                         @unique
  serialNumber          String?
  oneOfOne              Boolean                        @default(true)
  completedAt           DateTime?
  qualityStatus         String                         @default("PENDING")
  productCostSnapshot   Json
  inventoryStatus       String                         @default("AVAILABLE")
  etsyListingId         String?
  notes                 String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  batch                 ProductionBatch                @relation(fields: [batchId], references: [id], onDelete: Restrict)
  inventoryTransactions FinishedInventoryTransaction[]

  @@index([inventoryStatus, completedAt])
}

model FinishedInventoryTransaction {
  id               String         @id @default(cuid())
  productionUnitId String
  transactionAt    DateTime
  type             String
  orderId          String?
  notes            String?
  createdAt        DateTime       @default(now())
  unit             ProductionUnit @relation(fields: [productionUnitId], references: [id], onDelete: Restrict)

  @@index([productionUnitId, transactionAt])
}

model EtsyPayout {
  id              String                     @id @default(cuid())
  etsyPayoutId    String                     @unique
  payoutDate      DateTime
  amount          Decimal
  currency        String
  status          String
  bankReference   String?
  sourceHash      String
  firstImportedAt DateTime                   @default(now())
  lastImportedAt  DateTime                   @default(now())
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  reconciliations EtsyPayoutReconciliation[]

  @@index([payoutDate, status])
}

model EtsyPayoutReconciliation {
  id              String     @id @default(cuid())
  payoutId        String
  targetType      String
  targetId        String
  amount          Decimal
  currency        String
  fxDifferenceTry Decimal?
  confirmed       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  payout          EtsyPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@unique([payoutId, targetType, targetId])
}

model SalesDocument {
  id                String    @id @default(cuid())
  orderId           String?
  documentType      String
  documentNumber    String?
  status            String    @default("DRAFT")
  issueDate         DateTime?
  currency          String
  netAmount         Decimal
  vatAmount         Decimal
  grossAmount       Decimal
  validationJson    Json
  externalProvider  String?
  externalReference String?
  storedDocumentId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([documentType, documentNumber])
  @@index([orderId, status])
}

model ShipEntegraConnection {
  id                      String                      @id @default(cuid())
  status                  ShipEntegraConnectionStatus @default(NOT_CONFIGURED)
  accountReference        String?
  environment             ShipEntegraEnvironment
  operationMode           ShipEntegraOperationMode    @default(PLANNING_ONLY)
  connectedAt             DateTime?
  lastSuccessfulRequestAt DateTime?
  lastFailedRequestAt     DateTime?
  lastQuoteSyncAt         DateTime?
  lastShipmentSyncAt      DateTime?
  lastErrorCode           String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@unique([environment])
}

model ShipEntegraQuote {
  id                           String          @id @default(cuid())
  localOrderId                 String?
  packageProfileId             String?
  originCountry                String
  destinationCountry           String
  destinationPostalCodePartial String?
  weightBand                   String
  carrier                      String
  serviceCode                  String
  serviceName                  String
  incoterm                     String          @default("UNKNOWN")
  estimatedPrice               Decimal
  currency                     String
  fuelCost                     Decimal         @default(0)
  additionalFee                Decimal         @default(0)
  additionalFeeDescription     String?
  estimatedDeliveryMinDays     Int?
  estimatedDeliveryMaxDays     Int?
  quotePayloadHash             String
  requestAssumptionsJson       Json
  quotedAt                     DateTime
  expiresAt                    DateTime?
  selected                     Boolean         @default(false)
  source                       CostSource      @default(SHIPENTEGRA_ESTIMATE)
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  localOrder                   Order?          @relation(fields: [localOrderId], references: [id], onDelete: Restrict)
  packageProfile               PackageProfile? @relation(fields: [packageProfileId], references: [id], onDelete: Restrict)

  @@unique([quotePayloadHash, serviceCode])
  @@index([destinationCountry, packageProfileId, weightBand, quotedAt])
  @@index([localOrderId, selected])
}

model ShipEntegraConfirmation {
  id                      String                @id @default(cuid())
  localOrderId            String
  legalOperatingProfileId String
  selectedQuoteId         String?
  tokenHash               String                @unique
  previewPayloadHash      String
  confirmedBy             String
  confirmedAt             DateTime
  expiresAt               DateTime
  consumedAt              DateTime?
  createdAt               DateTime              @default(now())
  localOrder              Order                 @relation(fields: [localOrderId], references: [id], onDelete: Restrict)
  legalOperatingProfile   LegalOperatingProfile @relation(fields: [legalOperatingProfileId], references: [id], onDelete: Restrict)

  @@index([localOrderId, expiresAt, consumedAt])
}

model ShipEntegraShipmentOperation {
  id                 String                     @id @default(cuid())
  localOrderId       String
  idempotencyKey     String                     @unique
  externalReference  String                     @unique
  confirmationId     String
  status             ShipEntegraOperationStatus @default(PENDING)
  requestPayloadHash String
  externalShipmentId String?
  attemptCount       Int                        @default(0)
  lastErrorCode      String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([localOrderId, status])
}

model ShipEntegraShipment {
  id                     String                        @id @default(cuid())
  localOrderId           String                        @unique
  externalShipmentId     String                        @unique
  externalOrderReference String                        @unique
  carrier                String?
  serviceCode            String?
  serviceName            String?
  incoterm               String                        @default("UNKNOWN")
  shipmentStatus         String
  trackingNumber         String?
  trackingUrl            String?
  estimatedCost          Decimal?
  creationCost           Decimal?
  actualCost             Decimal?
  currency               String?
  labelDocumentId        String?
  createdRemotelyAt      DateTime?
  lastSyncedAt           DateTime?
  deliveredAt            DateTime?
  canceledAt             DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  localOrder             Order                         @relation(fields: [localOrderId], references: [id], onDelete: Restrict)
  labelDocument          StoredDocument?               @relation(fields: [labelDocumentId], references: [id], onDelete: Restrict)
  trackingEvents         ShipEntegraTrackingEvent[]
  snapshots              ShipEntegraShipmentSnapshot[]

  @@index([shipmentStatus, lastSyncedAt])
  @@index([trackingNumber])
}

model ShipEntegraTrackingEvent {
  id              String              @id @default(cuid())
  shipmentId      String
  externalEventId String
  statusCode      String?
  statusLabel     String?
  description     String
  eventLocation   String?
  eventTime       DateTime
  firstImportedAt DateTime            @default(now())
  createdAt       DateTime            @default(now())
  shipment        ShipEntegraShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, externalEventId])
  @@index([shipmentId, eventTime])
}

model ShipEntegraShipmentSnapshot {
  id               String              @id @default(cuid())
  shipmentId       String
  packageProfileId String?
  snapshotType     String
  payloadHash      String
  carrier          String?
  service          String?
  incoterm         String
  packageLengthCm  Decimal
  packageWidthCm   Decimal
  packageHeightCm  Decimal
  actualWeightKg   Decimal
  declaredValue    Decimal
  currency         String
  estimatedCost    Decimal?
  createdAt        DateTime            @default(now())
  shipment         ShipEntegraShipment @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  packageProfile   PackageProfile?     @relation(fields: [packageProfileId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, snapshotType, payloadHash])
}

model ShipEntegraApiCall {
  id               String                      @id @default(cuid())
  operation        String
  endpointCategory ShipEntegraEndpointCategory
  success          Boolean
  statusCode       Int?
  durationMs       Int
  requestReference String?
  errorCode        String?
  createdAt        DateTime                    @default(now())

  @@index([operation, createdAt])
  @@index([success, createdAt])
}

model ShippingCostAdjustment {
  id                 String     @id @default(cuid())
  localOrderId       String
  shipmentId         String?
  source             CostSource
  estimatedAmount    Decimal?
  actualAmount       Decimal
  currency           String
  varianceAmount     Decimal?
  variancePercentage Decimal?
  reason             String?
  createdAt          DateTime   @default(now())
  localOrder         Order      @relation(fields: [localOrderId], references: [id], onDelete: Restrict)

  @@index([localOrderId, createdAt])
}

model CustomsProfile {
  id                 String             @id @default(cuid())
  name               String
  originCountry      String
  destinationCountry String
  incoterm           String?
  status             String             @default("DRAFT")
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  source             String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([originCountry, destinationCountry, effectiveFrom, effectiveTo])
}

model TariffVersion {
  id                 String             @id @default(cuid())
  hsCode             String
  productDescription String
  material           String?
  originCountry      String
  destinationCountry String
  dutyRate           Decimal?
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  source             String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([hsCode, originCountry, destinationCountry, effectiveFrom])
}

model MicroExportCase {
  id                 String   @id @default(cuid())
  orderId            String?  @unique
  status             String   @default("DRAFT")
  exporterName       String
  customsStatus      String?
  etgbStatus         String   @default("PENDING")
  shipmentId         String?
  invoiceDocumentId  String?
  proformaDocumentId String?
  etgbDocumentId     String?
  customsDocumentId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, etgbStatus])
}

model TaxRuleVersion {
  id                 String             @id @default(cuid())
  name               String
  taxType            String
  rate               Decimal?
  threshold          Decimal?
  currency           String?
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  source             String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([taxType, effectiveFrom, effectiveTo])
}

model TaxObligation {
  id                 String             @id @default(cuid())
  taxType            String
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime
  status             String             @default("PLANNED")
  estimatedAmount    Decimal?
  filedAmount        Decimal?
  paidAmount         Decimal?
  currency           String             @default("TRY")
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  filingDocumentId   String?
  paymentDocumentId  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status, dueDate])
}

model VatPeriod {
  id                 String             @id @default(cuid())
  year               Int
  month              Int
  outputVat          Decimal            @default(0)
  inputVat           Decimal            @default(0)
  estimatedPayable   Decimal            @default(0)
  filedPayable       Decimal?
  status             String             @default("OPEN")
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([year, month])
}

model IncomeTaxEstimate {
  id                   String             @id @default(cuid())
  year                 Int
  period               String
  taxableBusinessBase  Decimal
  salaryIncomeIncluded Boolean            @default(false)
  estimatedTax         Decimal
  currency             String             @default("TRY")
  assumptionsJson      Json
  confirmationStatus   ConfirmationStatus @default(UNKNOWN)
  createdAt            DateTime           @default(now())

  @@unique([year, period])
}

model SgkMonthStatus {
  id                 String             @id @default(cuid())
  year               Int
  month              Int
  fourAActive        Boolean?
  fourBStatus        String             @default("UNKNOWN")
  debtAmount         Decimal?
  paymentAmount      Decimal?
  confirmationStatus ConfirmationStatus @default(UNKNOWN)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([year, month])
}

model AccountantPeriod {
  id                  String    @id @default(cuid())
  year                Int
  month               Int
  status              String    @default("OPEN")
  expectedDocuments   Int       @default(0)
  uploadedDocuments   Int       @default(0)
  missingDocuments    Int       @default(0)
  sentAt              DateTime?
  confirmedReceivedAt DateTime?
  accountantNotes     String?
  lockedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([year, month])
  @@index([status, year, month])
}
