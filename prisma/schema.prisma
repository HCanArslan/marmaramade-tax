generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 String                   @id @default(cuid())
  sku                String                   @unique
  title              String
  material           String?
  description        String?
  hsCode             String?
  widthCm            Decimal?
  heightCm           Decimal?
  handleLengthCm     Decimal?
  productWeightGrams Decimal?
  primaryColor       String?
  secondaryColor     String?
  lining             Boolean                  @default(false)
  interiorPocket     Boolean                  @default(false)
  closureType        String?
  baseType           String?
  oneOfOne           Boolean                  @default(true)
  active             Boolean                  @default(true)
  notes              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  costVersions       ProductCostVersion[]
  orderItems         OrderItem[]
  etsyListingLinks   EtsyListingProductLink[]
  materialCosts      ProductMaterialCost[]
  documents          StoredDocument[]
  goalProducts       GoalScenarioProduct[]

  @@index([active])
}

model ProductCostVersion {
  id                        String                @id @default(cuid())
  productId                 String
  effectiveFrom             DateTime
  effectiveTo               DateTime?
  materialCostTry           Decimal
  laborHours                Decimal
  laborHourlyRateTry        Decimal
  packagingCostTry          Decimal
  additionalDirectCostTry   Decimal
  notes                     String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  product                   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems                OrderItem[]
  materialComponents        ProductMaterialCost[]
  wastageRate               Decimal               @default(0)
  additionalMakerPaymentTry Decimal               @default(0)
  allocatedEquipmentCostTry Decimal               @default(0)
  changeReason              String?
  templateType              String?

  @@unique([productId, effectiveFrom])
  @@index([productId, effectiveFrom, effectiveTo])
}

model PackageProfile {
  id                String   @id @default(cuid())
  name              String   @unique
  lengthCm          Decimal
  widthCm           Decimal
  heightCm          Decimal
  actualWeightKg    Decimal
  volumetricDivisor Decimal  @default(5000)
  packagingCostTry  Decimal  @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Marketplace {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeProfile {
  id              String              @id @default(cuid())
  marketplace     String
  name            String
  country         String
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  listingCurrency String
  payoutCurrency  String
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  rules           FeeRule[]
  orders          Order[]
  snapshots       OrderCostSnapshot[]
  goalVersions    ProfitGoalVersion[]

  @@unique([marketplace, country, effectiveFrom])
  @@index([effectiveFrom, effectiveTo])
}

model FeeRule {
  id              String     @id @default(cuid())
  feeProfileId    String
  name            String
  category        String
  calculationType String
  percentageRate  Decimal?
  fixedAmount     Decimal?
  fixedCurrency   String?
  calculationBase String?
  vatApplicable   Boolean    @default(false)
  vatRate         Decimal    @default(0)
  minimumAmount   Decimal?
  maximumAmount   Decimal?
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  sourceUrl       String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  feeProfile      FeeProfile @relation(fields: [feeProfileId], references: [id], onDelete: Cascade)

  @@index([feeProfileId, category])
}

model BusinessProfileVersion {
  id                           String              @id @default(cuid())
  name                         String
  effectiveFrom                DateTime
  effectiveTo                  DateTime?
  businessStatus               String
  vatIdSubmittedToEtsy         Boolean
  etsyVatTreatment             String
  sellerFeeVatRate             Decimal
  accountantMonthlyTry         Decimal
  socialSecurityMonthlyTry     Decimal
  invoicingSoftwareMonthlyTry  Decimal
  bankingMonthlyTry            Decimal
  officeMonthlyTry             Decimal
  otherMonthlyBusinessCostsTry Decimal
  expectedMonthlyOrders        Int
  overheadAllocationMethod     String
  notes                        String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  orders                       Order[]
  snapshots                    OrderCostSnapshot[]

  @@unique([name, effectiveFrom])
  @@index([effectiveFrom, effectiveTo])
}

model ShippingQuote {
  id                 String           @id @default(cuid())
  originCountry      String
  originCity         String
  destinationCountry String
  destinationRegion  String?
  carrier            String
  serviceName        String
  incoterm           String
  packageLengthCm    Decimal
  packageWidthCm     Decimal
  packageHeightCm    Decimal
  actualWeightKg     Decimal
  volumetricDivisor  Decimal
  volumetricWeightKg Decimal
  billableWeightKg   Decimal
  shippingCost       Decimal
  shippingCurrency   String
  insuranceCost      Decimal
  fuelSurcharge      Decimal
  remoteAreaFee      Decimal
  pickupFee          Decimal
  otherCarrierFees   Decimal
  quoteDate          DateTime
  expirationDate     DateTime?
  source             String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  orders             Order[]
  aggregator         String?
  zone               String?
  packageProfileName String?
  baseShippingPrice  Decimal?
  planningDefault    Boolean          @default(false)
  activeExpected     Boolean          @default(false)
  transitDaysMin     Int?
  transitDaysMax     Int?
  documents          StoredDocument[]

  @@index([destinationCountry, quoteDate])
}

model CustomsQuote {
  id                     String           @id @default(cuid())
  originCountry          String
  destinationCountry     String
  hsCode                 String
  productDescription     String
  countryOfOrigin        String
  declaredValue          Decimal
  declaredValueCurrency  String
  customsDutyRate        Decimal
  customsDutyAmount      Decimal?
  additionalTariffRate   Decimal
  additionalTariffAmount Decimal?
  carrierProcessingFee   Decimal
  brokerageFee           Decimal
  customsClearanceFee    Decimal
  insuranceFee           Decimal
  otherDestinationFee    Decimal
  quoteDate              DateTime
  expirationDate         DateTime?
  source                 String?
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  orders                 Order[]
  productMaterial        String?
  productCategory        String?
  destinationTax         Decimal          @default(0)
  effectiveFrom          DateTime?
  documents              StoredDocument[]

  @@index([destinationCountry, hsCode, quoteDate])
}

model ExchangeRateSnapshot {
  id            String              @id @default(cuid())
  baseCurrency  String
  quoteCurrency String
  rate          Decimal
  source        String
  capturedAt    DateTime
  createdAt     DateTime            @default(now())
  orders        Order[]
  snapshots     OrderCostSnapshot[]
  goalVersions  ProfitGoalVersion[]

  @@unique([baseCurrency, quoteCurrency, capturedAt])
  @@index([capturedAt])
}

model Order {
  id                         String                  @id @default(cuid())
  orderNumber                String                  @unique
  orderDate                  DateTime
  marketplace                String
  destinationCountry         String
  destinationRegion          String?
  currency                   String
  orderStatus                String
  offsiteAdAttributed        Boolean                 @default(false)
  trailingEtsyRevenueUsd     Decimal                 @default(0)
  currencyConversionRequired Boolean                 @default(true)
  depositFeeApplies          Boolean                 @default(false)
  businessProfileVersionId   String
  feeProfileId               String
  exchangeRateSnapshotId     String
  shippingQuoteId            String?
  customsQuoteId             String?
  notes                      String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  businessProfileVersion     BusinessProfileVersion  @relation(fields: [businessProfileVersionId], references: [id])
  feeProfile                 FeeProfile              @relation(fields: [feeProfileId], references: [id])
  exchangeRateSnapshot       ExchangeRateSnapshot    @relation(fields: [exchangeRateSnapshotId], references: [id])
  shippingQuote              ShippingQuote?          @relation(fields: [shippingQuoteId], references: [id])
  customsQuote               CustomsQuote?           @relation(fields: [customsQuoteId], references: [id])
  items                      OrderItem[]
  snapshots                  OrderCostSnapshot[]
  legalOperatingProfileId    String?
  confirmedAt                DateTime?
  complianceComplete         Boolean                 @default(false)
  etsyReceiptId              String?                 @unique
  legalOperatingProfile      LegalOperatingProfile?  @relation(fields: [legalOperatingProfileId], references: [id])
  documents                  StoredDocument[]
  checklist                  OrderDocumentChecklist?
  adjustments                OrderAdjustment[]
  withholdingRecords         WithholdingRecord[]

  @@index([orderDate])
  @@index([destinationCountry])
}

model OrderItem {
  id                        String             @id @default(cuid())
  orderId                   String
  productId                 String
  quantity                  Int
  unitPrice                 Decimal
  unitCurrency              String
  sellerFundedDiscount      Decimal
  etsyFundedDiscount        Decimal
  shippingAllocated         Decimal
  giftWrapAllocated         Decimal
  taxCollectedByMarketplace Decimal
  productCostVersionId      String
  createdAt                 DateTime           @default(now())
  order                     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                   Product            @relation(fields: [productId], references: [id])
  productCostVersion        ProductCostVersion @relation(fields: [productCostVersionId], references: [id])

  @@index([orderId])
}

model OrderCostSnapshot {
  id                       String                 @id @default(cuid())
  orderId                  String
  businessProfileVersionId String
  feeProfileId             String
  exchangeRateSnapshotId   String
  grossRevenueUsd          Decimal
  totalCostUsd             Decimal
  totalCostTry             Decimal
  estimatedProfitUsd       Decimal
  estimatedProfitTry       Decimal
  assumptionsJson          String
  calculatedAt             DateTime               @default(now())
  order                    Order                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  businessProfileVersion   BusinessProfileVersion @relation(fields: [businessProfileVersionId], references: [id])
  feeProfile               FeeProfile             @relation(fields: [feeProfileId], references: [id])
  exchangeRateSnapshot     ExchangeRateSnapshot   @relation(fields: [exchangeRateSnapshotId], references: [id])
  lines                    OrderCostLine[]
  adjustments              OrderAdjustment[]

  @@index([orderId, calculatedAt])
}

model OrderCostLine {
  id                    String            @id @default(cuid())
  orderCostSnapshotId   String
  formulaName           String
  category              String
  calculationBase       Decimal?
  rate                  Decimal?
  fixedAmount           Decimal?
  sourceAmount          Decimal
  sourceCurrency        String
  convertedAmountUsd    Decimal
  convertedAmountTry    Decimal
  exchangeRateUsed      Decimal
  applicableProfileName String?
  applicableFeeVersion  String?
  metadataJson          String?
  createdAt             DateTime          @default(now())
  snapshot              OrderCostSnapshot @relation(fields: [orderCostSnapshotId], references: [id], onDelete: Restrict)

  @@index([orderCostSnapshotId, category])
}

model Scenario {
  id         String           @id @default(cuid())
  name       String
  inputsJson String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  results    ScenarioResult[]
}

model ScenarioResult {
  id                      String   @id @default(cuid())
  scenarioId              String
  grossRevenueUsd         Decimal
  estimatedProfitUsd      Decimal
  estimatedProfitTry      Decimal
  contributionMargin      Decimal
  operatingMargin         Decimal
  afterReserveMargin      Decimal
  calculationSnapshotJson String
  createdAt               DateTime @default(now())
  scenario                Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model MonthlyOverhead {
  id                String   @id @default(cuid())
  month             DateTime @unique
  accountantTry     Decimal
  socialSecurityTry Decimal
  softwareTry       Decimal
  bankingTry        Decimal
  officeTry         Decimal
  otherTry          Decimal
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  beforeJson String?
  afterJson  String?
  actor      String   @default("local-user")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  emailHash  String
  ipHash     String
  successful Boolean
  reasonCode String
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([emailHash, createdAt])
  @@index([ipHash, createdAt])
}

model AdminSecurityEvent {
  id         String   @id @default(cuid())
  eventType  String
  successful Boolean
  emailHash  String?
  ipHash     String?
  reasonCode String
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([eventType, createdAt])
}

model EtsyConnection {
  id                      String            @id @default(cuid())
  shopId                  String            @unique
  etsyUserId              String
  shopName                String?
  shopTitle               String?
  shopCurrency            String?
  shopUrl                 String?
  encryptedAccessToken    String
  encryptedRefreshToken   String
  accessTokenExpiresAt    DateTime
  scopes                  String
  connectedAt             DateTime          @default(now())
  disconnectedAt          DateTime?
  lastRefreshedAt         DateTime?
  lastSuccessfulApiCallAt DateTime?
  lastSuccessfulSyncAt    DateTime?
  status                  String            @default("ACTIVE")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  syncRuns                EtsySyncRun[]
  listings                EtsyListing[]
  receipts                EtsyReceipt[]
  payments                EtsyPayment[]
  ledgerEntries           EtsyLedgerEntry[]

  @@index([status])
}

model EtsyOAuthState {
  id          String    @id @default(cuid())
  stateHash   String    @unique
  verifier    String
  redirectUri String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([expiresAt, consumedAt])
}

model EtsySyncRun {
  id                    String            @id @default(cuid())
  connectionId          String
  syncType              String
  status                String            @default("RUNNING")
  cursor                String?
  startedAt             DateTime          @default(now())
  completedAt           DateTime?
  listingsImported      Int               @default(0)
  receiptsImported      Int               @default(0)
  paymentsImported      Int               @default(0)
  ledgerEntriesImported Int               @default(0)
  rateLimitRemaining    Int?
  retryAfterSeconds     Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  connection            EtsyConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  errors                EtsySyncError[]
  listings              EtsyListing[]
  receipts              EtsyReceipt[]
  payments              EtsyPayment[]
  ledgerEntries         EtsyLedgerEntry[]

  @@index([connectionId, startedAt])
  @@index([status])
}

model EtsySyncError {
  id         String      @id @default(cuid())
  syncRunId  String
  resource   String
  externalId String?
  code       String
  message    String
  retryable  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  syncRun    EtsySyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([syncRunId, createdAt])
}

model EtsyListing {
  id                       String                  @id @default(cuid())
  connectionId             String
  syncRunId                String?
  etsyListingId            String                  @unique
  sku                      String?
  title                    String
  description              String?
  state                    String
  priceAmount              Decimal
  priceCurrency            String
  buyerOriginalPrice       Decimal?
  buyerDiscountedPrice     Decimal?
  buyerDiscountAmount      Decimal?
  buyerDiscountPercentage  Decimal?
  buyerHasDiscount         Boolean?
  buyerPriceCurrency       String?
  discountStartAt          DateTime?
  discountEndAt            DateTime?
  manualDiscountPercentage Decimal?
  quantity                 Int
  taxonomyId               String?
  shopSectionId            String?
  shippingProfileId        String?
  returnPolicyId           String?
  url                      String?
  favorerCount             Int?
  listingType              String?
  isTaxable                Boolean?
  nonTaxable               Boolean?
  isCustomizable           Boolean?
  isPersonalizable         Boolean?
  tags                     String[]                @default([])
  materials                String[]                @default([])
  itemWeight               Decimal?
  itemWeightUnit           String?
  itemLength               Decimal?
  itemWidth                Decimal?
  itemHeight               Decimal?
  itemDimensionsUnit       String?
  processingMinDays        Int?
  processingMaxDays        Int?
  inventorySummary         Json?
  sourceCreatedAt          DateTime?
  sourceUpdatedAt          DateTime?
  sourceEndingAt           DateTime?
  sourceHash               String
  firstImportedAt          DateTime                @default(now())
  lastImportedAt           DateTime                @default(now())
  lastChangedAt            DateTime                @default(now())
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  connection               EtsyConnection          @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  syncRun                  EtsySyncRun?            @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  images                   EtsyListingImage[]
  productLink              EtsyListingProductLink?
  receiptItems             EtsyReceiptItem[]

  @@index([connectionId, state])
  @@index([sku])
}

model EtsyListingImage {
  id              String      @id @default(cuid())
  etsyImageId     String      @unique
  etsyListingId   String
  rank            Int
  urlFull         String
  urlThumbnail    String?
  sourceUpdatedAt DateTime?
  firstImportedAt DateTime    @default(now())
  lastImportedAt  DateTime    @default(now())
  listing         EtsyListing @relation(fields: [etsyListingId], references: [etsyListingId], onDelete: Cascade)

  @@index([etsyListingId, rank])
}

model EtsyListingProductLink {
  id            String      @id @default(cuid())
  etsyListingId String      @unique
  productId     String
  skuConflict   Boolean     @default(false)
  confirmedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  listing       EtsyListing @relation(fields: [etsyListingId], references: [etsyListingId], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
}

model EtsyReceipt {
  id                  String            @id @default(cuid())
  connectionId        String
  syncRunId           String?
  etsyReceiptId       String            @unique
  localOrderId        String?
  sourceCreatedAt     DateTime
  sourceUpdatedAt     DateTime?
  paidAt              DateTime?
  shippedAt           DateTime?
  paymentStatus       String?
  shipmentStatus      String?
  destinationCountry  String?
  destinationRegion   String?
  postalCodePrefix    String?
  buyerCurrency       String?
  subtotalAmount      Decimal
  shippingAmount      Decimal
  discountAmount      Decimal
  giftWrapAmount      Decimal
  taxAmount           Decimal
  totalAmount         Decimal
  refundAmount        Decimal
  currency            String
  sourceHash          String
  needsReconciliation Boolean           @default(false)
  firstImportedAt     DateTime          @default(now())
  lastImportedAt      DateTime          @default(now())
  lastChangedAt       DateTime          @default(now())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  connection          EtsyConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  syncRun             EtsySyncRun?      @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  items               EtsyReceiptItem[]
  payments            EtsyPayment[]

  @@index([connectionId, sourceCreatedAt])
  @@index([localOrderId])
}

model EtsyReceiptItem {
  id                String       @id @default(cuid())
  etsyTransactionId String       @unique
  etsyReceiptId     String
  etsyListingId     String?
  title             String
  sku               String?
  quantity          Int
  priceAmount       Decimal
  currency          String
  sourceCreatedAt   DateTime?
  firstImportedAt   DateTime     @default(now())
  lastImportedAt    DateTime     @default(now())
  receipt           EtsyReceipt  @relation(fields: [etsyReceiptId], references: [etsyReceiptId], onDelete: Cascade)
  listing           EtsyListing? @relation(fields: [etsyListingId], references: [etsyListingId], onDelete: SetNull)

  @@index([etsyReceiptId])
  @@index([etsyListingId])
}

model EtsyPayment {
  id              String         @id @default(cuid())
  connectionId    String
  syncRunId       String?
  etsyPaymentId   String         @unique
  etsyReceiptId   String?
  amount          Decimal
  adjustedAmount  Decimal
  shippingAmount  Decimal
  taxAmount       Decimal
  feeAmount       Decimal
  netAmount       Decimal
  currency        String
  buyerCurrency   String?
  paidAt          DateTime?
  sourceUpdatedAt DateTime?
  sourceHash      String
  firstImportedAt DateTime       @default(now())
  lastImportedAt  DateTime       @default(now())
  lastChangedAt   DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  connection      EtsyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  syncRun         EtsySyncRun?   @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  receipt         EtsyReceipt?   @relation(fields: [etsyReceiptId], references: [etsyReceiptId], onDelete: SetNull)

  @@index([connectionId, paidAt])
  @@index([etsyReceiptId])
}

model EtsyLedgerEntry {
  id                  String         @id @default(cuid())
  connectionId        String
  syncRunId           String?
  etsyLedgerEntryId   String         @unique
  etsyLedgerId        String?
  entryType           String
  originalDescription String?
  mappedCategory      String
  mappingConfidence   Decimal
  manualReview        Boolean        @default(false)
  reviewStatus        String         @default("UNREVIEWED")
  amount              Decimal
  runningBalance      Decimal?
  currency            String
  sourceCreatedAt     DateTime
  sourceUpdatedAt     DateTime?
  sourceHash          String
  firstImportedAt     DateTime       @default(now())
  lastImportedAt      DateTime       @default(now())
  lastChangedAt       DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  connection          EtsyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  syncRun             EtsySyncRun?   @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([connectionId, sourceCreatedAt])
  @@index([mappedCategory, manualReview])
}

model EtsyWebhookEvent {
  id               String    @id @default(cuid())
  webhookId        String    @unique
  eventType        String
  shopId           String
  resourceUrl      String
  payloadHash      String
  webhookTimestamp DateTime
  processedAt      DateTime?
  status           String    @default("VERIFIED")
  createdAt        DateTime  @default(now())

  @@index([shopId, createdAt])
}

model EtsyImportMapping {
  id                  String   @id @default(cuid())
  originalType        String
  originalDescription String?
  mappedCategory      String
  confidence          Decimal
  approved            Boolean  @default(false)
  unrelated           Boolean  @default(false)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([originalType, originalDescription])
}

enum OperatingMode {
  ARTISAN_TAX_EXEMPTION
  SOLE_PROPRIETORSHIP
  LIMITED_COMPANY
  PLANNING_ONLY
}

enum LegalSellerType {
  TAX_EXEMPT_ARTISAN
  INDIVIDUAL
  SOLE_PROPRIETORSHIP
  COMPANY
}

enum OrphanPensionRiskStatus {
  UNKNOWN
  UNDER_REVIEW
  CONFIRMED_NO_IMPACT
  CONFIRMED_IMPACT
  MANUAL_REVIEW_REQUIRED
}

enum ComplianceCaseStatus {
  DRAFT
  SUBMITTED
  WAITING_FOR_RESPONSE
  RESPONSE_RECEIVED
  NEEDS_CLARIFICATION
  RESOLVED
  ARCHIVED
}

enum ComplianceInstitution {
  SGK
  GIB
  TAX_OFFICE
  ETSY
  SHIPENTEGRA
  BANK
  ACCOUNTANT
  OTHER
}

enum DocumentCategory {
  ETSY_ORDER
  ETSY_PAYMENT
  ETSY_LEDGER
  PRODUCT_PHOTO
  PACKAGE_PHOTO
  SALES_DOCUMENT
  PROFORMA
  SHIPENTEGRA_LABEL
  SHIPENTEGRA_INVOICE
  ETGB
  CUSTOMS_CALCULATION
  DDP_CALCULATION
  TRACKING_DOCUMENT
  BANK_PAYOUT
  BANK_WITHHOLDING
  MATERIAL_RECEIPT
  PACKAGING_RECEIPT
  RETURN_DOCUMENT
  CUSTOMER_CORRESPONDENCE
  TAX_EXEMPTION_CERTIFICATE
  SGK_RESPONSE
  TAX_OFFICE_RESPONSE
  ETSY_SUPPORT_RESPONSE
  SHIPENTEGRA_RESPONSE
  ACCOUNTANT_OPINION
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PENDING_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
  ARCHIVED
}

enum ConfidentialityLevel {
  INTERNAL
  SENSITIVE
  HIGHLY_SENSITIVE
}

enum WithholdingBaseType {
  BANK_NET_PAYOUT
  ETSY_GROSS_REVENUE
  MANUAL
  UNKNOWN_PENDING_CONFIRMATION
}

enum PeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum ProfitMetric {
  MARKETPLACE_CONTRIBUTION
  PRODUCT_CONTRIBUTION
  AFTER_LABOR
  OPERATING_PROFIT
  REALISTIC_AFTER_TAX_AND_RESERVES
}

enum PlanningMode {
  AVERAGE_PRODUCT
  PRODUCT_COMBINATION
  CURRENT_INVENTORY
  CUSTOM_MIX
}

model LegalOperatingProfile {
  id                                   String                  @id @default(cuid())
  name                                 String
  effectiveFrom                        DateTime
  effectiveTo                          DateTime?
  operatingMode                        OperatingMode
  legalSellerName                      String
  legalSellerType                      LegalSellerType
  makerName                            String
  etsyAccountHolderName                String
  etsyTaxpayerName                     String
  bankAccountHolderName                String
  exporterName                         String
  shipEntegraAccountHolderName         String
  businessStatus                       String
  artisanTaxExemptionEnabled           Boolean                 @default(false)
  artisanTaxExemptionCertificateNumber String?
  artisanTaxExemptionCertificateDate   DateTime?
  artisanTaxExemptionExpiryDate        DateTime?
  orphanPensionRiskStatus              OrphanPensionRiskStatus @default(UNKNOWN)
  sgkWrittenConfirmationStatus         String                  @default("UNKNOWN")
  sgkWrittenConfirmationDate           DateTime?
  vatIdSubmittedToEtsy                 Boolean                 @default(false)
  sellerFeeVatTreatment                String
  incomeTaxReserveRate                 Decimal                 @default(0)
  withholdingTaxRate                   Decimal                 @default(0)
  expectedMonthlyOrders                Int                     @default(1)
  fourAEmploymentActive                Boolean                 @default(false)
  companyStartDate                     DateTime?
  notes                                String?
  createdAt                            DateTime                @default(now())
  updatedAt                            DateTime                @updatedAt
  orders                               Order[]
  documents                            StoredDocument[]
  complianceCases                      ComplianceCase[]
  goals                                ProfitGoal[]
  withholdingRecords                   WithholdingRecord[]

  @@unique([name, effectiveFrom])
  @@index([effectiveFrom, effectiveTo])
  @@index([operatingMode, effectiveFrom])
}

model TaxExemptionLimitVersion {
  id             String   @id @default(cuid())
  year           Int
  annualLimitTry Decimal
  effectiveFrom  DateTime
  source         String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([year, effectiveFrom])
}

model ComplianceCase {
  id                             String                 @id @default(cuid())
  title                          String
  institution                    ComplianceInstitution
  topic                          String
  status                         ComplianceCaseStatus   @default(DRAFT)
  openedAt                       DateTime               @default(now())
  submittedAt                    DateTime?
  responseDueAt                  DateTime?
  resolvedAt                     DateTime?
  summary                        String?
  decision                       String?
  referenceNumber                String?
  contactChannel                 String?
  relatedLegalOperatingProfileId String?
  createdAt                      DateTime               @default(now())
  updatedAt                      DateTime               @updatedAt
  relatedLegalOperatingProfile   LegalOperatingProfile? @relation(fields: [relatedLegalOperatingProfileId], references: [id])
  documents                      StoredDocument[]

  @@index([status, responseDueAt])
  @@index([institution, topic])
}

model StoredDocument {
  id                      String                       @id @default(cuid())
  originalFilename        String
  safeStorageFilename     String
  blobUrl                 String
  blobPath                String                       @unique
  mimeType                String
  sizeBytes               Int
  checksumSha256          String
  category                DocumentCategory
  status                  DocumentStatus               @default(PENDING_REVIEW)
  confidentialityLevel    ConfidentialityLevel         @default(SENSITIVE)
  orderId                 String?
  productId               String?
  etsyReceiptId           String?
  shippingQuoteId         String?
  customsQuoteId          String?
  legalOperatingProfileId String?
  complianceCaseId        String?
  documentDate            DateTime?
  uploadedAt              DateTime                     @default(now())
  uploadedBy              String
  verifiedAt              DateTime?
  verifiedBy              String?
  expiresAt               DateTime?
  archivedAt              DateTime?
  deletedAt               DateTime?
  notes                   String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  order                   Order?                       @relation(fields: [orderId], references: [id])
  product                 Product?                     @relation(fields: [productId], references: [id])
  shippingQuote           ShippingQuote?               @relation(fields: [shippingQuoteId], references: [id])
  customsQuote            CustomsQuote?                @relation(fields: [customsQuoteId], references: [id])
  legalOperatingProfile   LegalOperatingProfile?       @relation(fields: [legalOperatingProfileId], references: [id])
  complianceCase          ComplianceCase?              @relation(fields: [complianceCaseId], references: [id])
  checklistItems          OrderDocumentChecklistItem[]

  @@index([checksumSha256, deletedAt])
  @@index([orderId, category, status])
  @@index([complianceCaseId])
}

model DocumentRequirementRule {
  id                    String           @id @default(cuid())
  name                  String
  category              DocumentCategory
  destinationCountry    String?
  operatingMode         OperatingMode?
  incoterm              String?
  carrier               String?
  returnedOnly          Boolean?
  artisanExemptionOnly  Boolean?
  confirmedSnapshotOnly Boolean?
  required              Boolean          @default(true)
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([effectiveFrom, effectiveTo, category])
}

model OrderDocumentChecklist {
  id                  String                       @id @default(cuid())
  orderId             String                       @unique
  completenessPercent Decimal                      @default(0)
  complianceComplete  Boolean                      @default(false)
  generatedAt         DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  order               Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items               OrderDocumentChecklistItem[]
}

model OrderDocumentChecklistItem {
  id          String                 @id @default(cuid())
  checklistId String
  category    DocumentCategory
  required    Boolean                @default(true)
  documentId  String?
  verified    Boolean                @default(false)
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  checklist   OrderDocumentChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  document    StoredDocument?        @relation(fields: [documentId], references: [id])

  @@unique([checklistId, category])
}

model ProductMaterialCost {
  id                   String              @id @default(cuid())
  productId            String
  productCostVersionId String?
  componentType        String
  description          String?
  quantity             Decimal             @default(1)
  unitCostTry          Decimal
  totalCostTry         Decimal
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  product              Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productCostVersion   ProductCostVersion? @relation(fields: [productCostVersionId], references: [id], onDelete: Cascade)

  @@index([productId, componentType])
  @@index([productCostVersionId])
}

model OrderAdjustment {
  id           String             @id @default(cuid())
  orderId      String
  snapshotId   String?
  category     String
  amount       Decimal
  currency     String
  amountUsd    Decimal
  amountTry    Decimal
  reason       String
  evidenceNote String?
  createdBy    String
  createdAt    DateTime           @default(now())
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  snapshot     OrderCostSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model WithholdingRecord {
  id                      String                 @id @default(cuid())
  orderId                 String?
  legalOperatingProfileId String?
  recordDate              DateTime
  expectedWithholdingRate Decimal                @default(0)
  expectedWithholdingTry  Decimal                @default(0)
  actualWithholdingTry    Decimal?
  withholdingBaseType     WithholdingBaseType    @default(UNKNOWN_PENDING_CONFIRMATION)
  withholdingBaseTry      Decimal?
  bankReference           String?
  verificationStatus      String                 @default("PENDING")
  notes                   String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  order                   Order?                 @relation(fields: [orderId], references: [id])
  legalOperatingProfile   LegalOperatingProfile? @relation(fields: [legalOperatingProfileId], references: [id])

  @@index([recordDate, verificationStatus])
}

model ProfitGoal {
  id                   String                @id @default(cuid())
  name                 String
  periodType           PeriodType
  startDate            DateTime
  endDate              DateTime
  targetProfitAmount   Decimal
  targetProfitCurrency String
  profitMetric         ProfitMetric          @default(REALISTIC_AFTER_TAX_AND_RESERVES)
  planningMode         PlanningMode
  operatingProfileId   String
  scenarioSettings     Json
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  operatingProfile     LegalOperatingProfile @relation(fields: [operatingProfileId], references: [id])
  versions             ProfitGoalVersion[]
  scenarios            GoalScenario[]

  @@index([startDate, endDate])
}

model ProfitGoalVersion {
  id                     String                @id @default(cuid())
  profitGoalId           String
  versionNumber          Int
  targetProfitAmount     Decimal
  targetProfitCurrency   String
  exchangeRateSnapshotId String?
  feeProfileId           String?
  assumptionsJson        Json
  calculatedAt           DateTime              @default(now())
  profitGoal             ProfitGoal            @relation(fields: [profitGoalId], references: [id], onDelete: Cascade)
  exchangeRateSnapshot   ExchangeRateSnapshot? @relation(fields: [exchangeRateSnapshotId], references: [id])
  feeProfile             FeeProfile?           @relation(fields: [feeProfileId], references: [id])
  scenarios              GoalScenario[]

  @@unique([profitGoalId, versionNumber])
}

model GoalScenario {
  id                  String                @id @default(cuid())
  profitGoalId        String
  profitGoalVersionId String?
  name                String
  planningMode        PlanningMode
  objective           String
  settingsJson        Json
  exactResult         Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  profitGoal          ProfitGoal            @relation(fields: [profitGoalId], references: [id], onDelete: Cascade)
  profitGoalVersion   ProfitGoalVersion?    @relation(fields: [profitGoalVersionId], references: [id])
  products            GoalScenarioProduct[]
  result              GoalScenarioResult?

  @@index([profitGoalId, createdAt])
}

model GoalScenarioProduct {
  id             String       @id @default(cuid())
  goalScenarioId String
  productId      String
  quantity       Int
  minQuantity    Int          @default(0)
  maxQuantity    Int?
  unitProfitUsd  Decimal
  laborHours     Decimal
  scenario       GoalScenario @relation(fields: [goalScenarioId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])

  @@unique([goalScenarioId, productId])
}

model GoalScenarioResult {
  id                       String       @id @default(cuid())
  goalScenarioId           String       @unique
  estimatedProfitUsd       Decimal
  estimatedProfitTry       Decimal
  requiredUnits            Int?
  requiredRevenueUsd       Decimal
  totalLaborHours          Decimal
  totalFeesUsd             Decimal
  totalLogisticsUsd        Decimal
  totalMaterialsTry        Decimal
  targetAchievementPercent Decimal
  warningsJson             Json
  calculationSnapshotJson  Json
  createdAt                DateTime     @default(now())
  scenario                 GoalScenario @relation(fields: [goalScenarioId], references: [id], onDelete: Cascade)
}

model MonthlyActualSummary {
  id                       String   @id @default(cuid())
  month                    DateTime
  currency                 String
  confirmedRevenue         Decimal
  confirmedRealisticProfit Decimal
  openOrderExpectedProfit  Decimal
  actualWithholding        Decimal
  snapshotJson             Json
  createdAt                DateTime @default(now())

  @@unique([month, currency])
}
